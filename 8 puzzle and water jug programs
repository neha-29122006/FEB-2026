from collections import deque
def water(j1,j2,goal):
    que=deque([((0,0),[])])
    vs=set()
    while que:
        (a,b),path=que.popleft()
        if (a,b) in vs:
            continue
        vs.add((a,b))
        path=path+[(a,b)]
        if a==goal or b==goal:
            return path
        new_state=[(j1,b),(a,j2),(0,b),(a,0)]
        pour=min(a,j2-b)
        new_state.append((a-pour,b+pour))
        pour1=min(j1-a,b)
        new_state.append((a+pour1,b-pour1))
        for state in new_state:
            if state not in vs:
                que.append((state,path))
    return None
        


