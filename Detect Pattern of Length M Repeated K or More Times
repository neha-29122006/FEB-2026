class Solution:
    def containsPattern(self, arr, m, k):
        n = len(arr)
        count = 0
        
        for i in range(n - m):
            if arr[i] == arr[i + m]:
                count += 1
                if count == (k - 1) * m:
                    return True
            else:
                count = 0
                    
        return False
